# Copy to .env and edit. Used by docker-compose.yml.

# Postgres password for the bundled db service (required).
POSTGRES_PASSWORD=change-me-to-something-long

# The site's public base URL — used in email links and Stripe return URLs. Set it
# to the https URL your reverse proxy serves (e.g. https://booklet.example.com).
BOOKLET_PUBLIC_URL=https://booklet.example.com

# --- optional features (leave unset to keep them off) ---

# Public sign-up at /signup is OPEN by default; set to 0/false to CLOSE it.
# BOOKLET_ALLOW_REGISTRATION=false

# Email (password-reset links + invites).
# BOOKLET_SMTP_HOST=smtp.example.com
# BOOKLET_SMTP_PORT=587
# BOOKLET_SMTP_USER=booklet@example.com
# BOOKLET_SMTP_PASSWORD=
# BOOKLET_SMTP_TLS=starttls          # starttls | implicit | none
# BOOKLET_MAIL_FROM=Booklet <booklet@example.com>

# Billing (Stripe). The webhook endpoint is POST /billing/webhook on the admin
# listener — see the deploy notes if you use billing.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
